#include <stdio.h>
    int main(){
        int n,i;
        int proximo=0,primeiro=0,segundo=0;

        printf("Defina a quantidade de termos: ");
        scanf("%d",&n);
        printf("Primeiro termo:");
        scanf("%d",&primeiro);
        printf("segundo termo: ");
        scanf("%d",&segundo);

        for(i=0;i<=n;i++){
         
         printf(" %d ",primeiro);
         
          proximo=primeiro+segundo;
          primeiro=segundo;
          segundo=proximo;
          
        }
        return 0;
    }
